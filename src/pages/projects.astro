---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Import all description files
const esDescriptions = import.meta.glob('../project-descriptions/*/descripcion.md', { query: '?raw', import: 'default' });
const enDescriptions = import.meta.glob('../project-descriptions/*/descripcion.en.md', { query: '?raw', import: 'default' });

// Load images natively
const allImages = import.meta.glob('../assets/*/*.{png,jpg,jpeg,webp}', { eager: true });

// Get all project folders
const projectFolders = Object.keys(esDescriptions).map(path => {
    const parts = path.split('/');
    return parts[parts.length - 2];
});

// List of project folders to show on the Projects page.
const visibleProjectFolders = [
    'SAIF',
    'Tecpoint',
	'LasTejas',
	'GZ Connect',
	'Spiritual Journey',
];

const filteredFolders = projectFolders.filter(folder => visibleProjectFolders.includes(folder));

function parseProjectData(content: string) {
    const lines = content.split('\n');
    const title = lines[0].replace(/# /g, '').trim();
    const summary = lines[1].trim();
    
    const stackIndex = lines.findIndex(l => l.includes('## Stack'));
    const linksIndex = lines.findIndex(l => l.includes('## Links'));
    
    const stack = stackIndex !== -1 ? lines[stackIndex + 1].split(',').map(s => s.trim()) : [];
    const linksRaw = linksIndex !== -1 ? lines.slice(linksIndex + 1).filter(l => l.trim()) : [];
    
    const links = linksRaw.map(l => {
        const match = l.match(/\[(.*)\]\((.*)\)/);
        if (match) return { label: match[1], url: match[2] };
        return { label: l.trim(), url: null };
    });

    return { title, summary, stack, links };
}

const projects = await Promise.all(filteredFolders.map(async (folder) => {
    const esPath = `../project-descriptions/${folder}/descripcion.md`;
    const enPath = `../project-descriptions/${folder}/descripcion.en.md`;
    
    const esContent = await esDescriptions[esPath]() as string;
    const enContent = await enDescriptions[enPath]() as string;
    
    const esData = parseProjectData(esContent);
    const enData = parseProjectData(enContent);

    const projectImages = Object.keys(allImages)
        .filter(path => path.includes(`/${folder}/`))
        .map(path => (allImages[path] as any).default.src);

    return {
		slug: folder,
		esData,
		enData,
		images: projectImages.slice(0, 3)
	};
}));

const translations = {
	subtitle: { en: 'Selected Work', es: 'Trabajos Seleccionados' },
	title: { en: 'Projects', es: 'Proyectos' },
	description: { en: 'A collection of projects showcasing my skills in development.', es: 'Una colección de proyectos que muestran mis habilidades en desarrollo.' },
    inDevelopment: { en: 'In Development', es: 'En desarrollo' },
    customSoftware: { en: 'Custom Software', es: 'Software a medida' },
    viewDetails: { en: 'View Details', es: 'Ver Detalles' }
};
---

<Layout title={`Projects | Hesler Zacasa`}>
	<Header />
	
	<main class="bg-white dark:bg-gray-950 min-h-screen pb-32">
		<!-- Introduction Header -->
		<section class="max-w-6xl mx-auto pt-32 pb-16 px-6 sm:px-8">
			<div class="max-w-2xl fade-in">
				<p class="text-xs sm:text-sm font-semibold text-gray-500 dark:text-gray-400 mb-3 sm:mb-4 tracking-wider uppercase" data-en={translations.subtitle.en} data-es={translations.subtitle.es}>{translations.subtitle.en}</p>
				<h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 dark:text-white tracking-tight" data-en={translations.title.en} data-es={translations.title.es}>
					{translations.title.en}
				</h1>
				<p class="mt-4 sm:mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed font-medium" data-en={translations.description.en} data-es={translations.description.es}>
					{translations.description.en}
				</p>
			</div>
		</section>

		<!-- Project Stories Section -->
		<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col gap-24 sm:gap-32 md:gap-40">
			{projects.map((project, idx) => {
				const isEven = idx % 2 === 0;
				return (
					<div class={`project-row flex flex-col lg:flex-row items-center gap-10 lg:gap-16 w-full ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}>
						{/* Image Column */}
						{project.images.length > 0 && (
							<div class="project-img-wrapper flex-1 w-full lg:w-1/2">
								<div class="relative overflow-hidden rounded-[2.5rem] border border-gray-200/60 dark:border-gray-800/80 bg-gray-50 dark:bg-gray-950 shadow-xl aspect-[16/10] group">
									<img 
										src={project.images[0]} 
										alt={project.esData.title} 
										class="w-full h-full object-cover object-top transform scale-100 group-hover:scale-[1.03] transition-transform duration-[1200ms] ease-out" 
										loading="lazy" 
									/>
									
									{/* Status Badges overlaying the image */}
									{(project.slug === 'HeyFood' || project.slug === 'MINIPOS' || project.slug === 'Spiritual Journey' || project.slug === 'SAIF') && (
										<div class="absolute top-6 left-6 z-10">
											<div class="px-4 py-2 rounded-full bg-black/60 backdrop-blur-md border border-white/10 text-[10px] font-bold uppercase tracking-widest text-white shadow-lg">
												{project.slug === 'HeyFood' && (
													<>
														<span class="locale-es">{translations.inDevelopment.es}</span>
														<span class="locale-en">{translations.inDevelopment.en}</span>
													</>
												)}
												{project.slug === 'MINIPOS' && (
													<>
														<span class="locale-es">{translations.customSoftware.es}</span>
														<span class="locale-en">{translations.customSoftware.en}</span>
													</>
												)}
												{project.slug === 'SAIF' && (
													<>
														<span class="locale-es">Sistema Administrativo</span>
														<span class="locale-en">Admin System</span>
													</>
												)}
												{project.slug === 'Spiritual Journey' && (
													<>
														<span class="locale-es">Proyecto Personal</span>
														<span class="locale-en">Personal Project</span>
													</>
												)}
											</div>
										</div>
									)}
								</div>
							</div>
						)}

						{/* Info Column */}
						<div class="project-info-wrapper flex-1 w-full lg:w-1/2 flex flex-col justify-center">
							<h3 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-4 leading-tight">
								<span class="locale-es">{project.esData.title}</span>
								<span class="locale-en">{project.enData.title}</span>
							</h3>
							
							<p class="text-base sm:text-lg text-gray-600 dark:text-gray-400 mb-6 leading-relaxed font-medium">
								<span class="locale-es">{project.esData.summary}</span>
								<span class="locale-en">{project.enData.summary}</span>
							</p>

							<!-- Stack Badges -->
							<div class="flex flex-wrap gap-2 mb-8">
								{project.esData.stack.map((tech) => (
									<span class="px-3.5 py-1.5 text-xs font-bold uppercase tracking-wider rounded-full bg-gray-100 dark:bg-gray-800/80 text-gray-700 dark:text-gray-300 border border-gray-200/40 dark:border-gray-700/40 shadow-sm cursor-default hover:bg-gray-205 dark:hover:bg-gray-700 transition-all">
										{tech}
									</span>
								))}
							</div>

							<!-- Action Buttons -->
							<div class="flex items-center gap-4">
								{/* Link to detail page */}
								<a 
									href={`/projects/${project.slug}`} 
									class="px-6 py-3 text-xs font-bold text-white bg-[#243e36] hover:bg-[#2d4940] rounded-full transition-all flex items-center gap-1.5 shadow-lg shadow-[#243e36]/30 hover:scale-105 active:scale-95 duration-300 cursor-pointer"
								>
									<span class="locale-es">{translations.viewDetails.es}</span>
									<span class="locale-en">{translations.viewDetails.en}</span>
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
									</svg>
								</a>

								{/* Direct site link if available and not Private */}
								{project.esData.links.length > 0 && project.esData.links[0].label !== 'Privado' && project.esData.links[0].label !== 'Private' && project.esData.links[0].url && (
									<a 
										href={project.esData.links[0].url} 
										target="_blank" 
										rel="noopener noreferrer" 
										class="px-6 py-3 text-xs font-bold text-gray-700 dark:text-white/90 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/20 border border-gray-200 dark:border-white/20 rounded-full transition-all flex items-center gap-1.5 backdrop-blur-sm hover:scale-105 active:scale-95 duration-300 cursor-pointer"
									>
										<span class="locale-es">{project.esData.links[0].label}</span>
										<span class="locale-en">{project.enData.links[0]?.label || project.esData.links[0].label}</span>
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
										</svg>
									</a>
								)}
							</div>
						</div>
					</div>
				);
			})}
		</section>
	</main>

	<Footer />

	<script>
		import { gsap } from "gsap";
		import { ScrollTrigger } from "gsap/ScrollTrigger";

		gsap.registerPlugin(ScrollTrigger);

		const initAnimations = () => {
			// Intro Header intersection observer
			const observerOptions = {
				root: null,
				rootMargin: '0px',
				threshold: 0.1
			};
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, observerOptions);
			document.querySelectorAll('.fade-in').forEach(el => {
				observer.observe(el);
			});

			// GSAP ScrollTrigger animations for project rows
			const rows = document.querySelectorAll('.project-row');
			rows.forEach((row, idx) => {
				const isEven = idx % 2 === 0;
				const imgWrapper = row.querySelector('.project-img-wrapper');
				const infoWrapper = row.querySelector('.project-info-wrapper');

				if (imgWrapper) {
					gsap.fromTo(imgWrapper,
						{
							x: isEven ? 80 : -80,
							opacity: 0,
							scale: 0.95
						},
						{
							x: 0,
							opacity: 1,
							scale: 1,
							duration: 1.2,
							ease: "power4.out",
							scrollTrigger: {
								trigger: row,
								start: "top 82%",
								toggleActions: "play none none none"
							}
						}
					);
				}

				if (infoWrapper) {
					const children = Array.from(infoWrapper.children);
					gsap.fromTo(children,
						{
							y: 35,
							opacity: 0
						},
						{
							y: 0,
							opacity: 1,
							duration: 0.8,
							stagger: 0.12,
							ease: "power3.out",
							scrollTrigger: {
								trigger: row,
								start: "top 82%",
								toggleActions: "play none none none"
							}
						}
					);
				}
			});
		};

		// Run animations on initial load
		initAnimations();
		
		// Run animations on Astro client routing transitions
		document.addEventListener("astro:page-load", () => {
			// Clean up old ScrollTriggers to prevent leaks
			ScrollTrigger.getAll().forEach(t => t.kill());
			initAnimations();
		});
	</script>
</Layout>

<style>
	@reference "../styles/global.css";
</style>
